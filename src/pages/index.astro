---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { heroSocials } from '../config/site';
import { Image } from 'astro:assets';

interface RssItem {
  title: string;
  link: string;
  pubDate: string;
  description: string;
  image: string;
  categories: string[];
}

let rssItems: RssItem[] = [];

try {
  const res = await fetch('https://empty.coffee/rss/', {
    headers: { 'User-Agent': 'mike.lapidak.is site builder' },
    signal: AbortSignal.timeout(8000),
  });
  if (res.ok) {
    const xml = await res.text();
    const items = xml.match(/<item>[\s\S]*?<\/item>/g) ?? [];
    rssItems = items.slice(0, 5).map(item => {
      const get = (tag: string) => {
        const cdata = item.match(new RegExp(`<${tag}[^>]*><!\\[CDATA\\[([\\s\\S]*?)\\]\\]><\\/${tag}>`));
        if (cdata) return cdata[1];
        const plain = item.match(new RegExp(`<${tag}[^>]*>([\\s\\S]*?)<\\/${tag}>`));
        return plain ? plain[1] : '';
      };
      const imageMatch = item.match(/<media:content url="([^"]+)"/);
      const categories = [...item.matchAll(/<category><!\[CDATA\[(.*?)\]\]><\/category>/g)]
        .map(m => m[1]).slice(0, 3);
      return {
        title: get('title').trim(),
        link: get('link').trim(),
        pubDate: get('pubDate').trim(),
        description: get('description').replace(/<[^>]+>/g, '').trim().slice(0, 140),
        image: imageMatch?.[1] ?? '',
        categories,
      };
    });
  }
} catch {
  // RSS unavailable at build time — degrade gracefully
}

const personJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Mike Lapidakis',
  url: 'https://mike.lapidak.is',
  jobTitle: 'Solutions Architect Manager',
  worksFor: { '@type': 'Organization', name: 'Amazon Web Services' },
  sameAs: [
    'https://linkedin.com/in/mikelapidakis',
    'https://github.com/mlapidakis',
    'https://bsky.app/profile/mike.lapidak.is',
    'https://lap.social/@mike',
    'https://glass.photo/lap',
    'https://empty.coffee',
  ],
};
---

<Base
  title="Mike Lapidakis"
  description="Solutions Architect Manager at AWS specializing in security, networking, and resilience. Photographer and tinkerer based in Denver, CO."
>
  <script type="application/ld+json" set:html={JSON.stringify(personJsonLd)} />
  <Nav />

  <main>
    <!-- Hero -->
    <section class="hero">
      <div class="container">
        <div class="hero__inner">
          <div class="hero__avatar animate-fade-up">
            <Image
              src="/profile.jpg"
              alt="Mike Lapidakis"
              width={112}
              height={112}
              class="hero__photo"
              onerror="this.style.display='none'"
            />
          </div>

          <div class="hero__content">
            <h1 class="hero__name display animate-fade-up animate-delay-1">
              Mike<br/>Lapidakis
            </h1>

            <p class="hero__role animate-fade-up animate-delay-2">
              Solutions Architect Manager &middot; AWS &middot; Denver, CO
            </p>

            <p class="hero__bio animate-fade-up animate-delay-3">
              I'm a tinkerer, a dad, a cloud computing practitioner, and an aspiring
              photographer. I'm always learning, mostly by not following instructions
              and fixing stuff when it breaks.
            </p>

            <ul class="hero__links animate-fade-up animate-delay-4">
              {heroSocials.map(link => (
                <li>
                  <a href={link.href} target="_blank" rel={`noopener${link.rel ? ` ${link.rel}` : ''}`} class="hero__link">
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Writing from empty.coffee -->
    {rssItems.length > 0 && (
      <section class="writing">
        <div class="container">
          <div class="section-header">
            <h2 class="section-label">Writing</h2>
            <a href="https://empty.coffee" target="_blank" rel="noopener" class="section-more">
              empty.coffee &rarr;
            </a>
          </div>
          <ol class="post-list">
            {rssItems.map((item, i) => (
              <li class="post-item">
                <a href={item.link} target="_blank" rel="noopener" class="post-card">
                  {item.image && (
                    <div class="post-thumb">
                      <img
                        src={item.image}
                        alt=""
                        loading={i === 0 ? 'eager' : 'lazy'}
                        decoding="async"
                      />
                    </div>
                  )}
                  <div class="post-body">
                    <div class="post-meta">
                      <time class="post-date">
                        {new Date(item.pubDate).toLocaleDateString('en-US', {
                          year: 'numeric',
                          month: 'short',
                          day: 'numeric',
                        })}
                      </time>
                      {item.categories.length > 0 && (
                        <ul class="post-cats" aria-label="categories">
                          {item.categories.map(cat => (
                            <li class="post-cat">{cat}</li>
                          ))}
                        </ul>
                      )}
                    </div>
                    <h3 class="post-title">{item.title}</h3>
                    {item.description && (
                      <p class="post-desc">{item.description}&hellip;</p>
                    )}
                  </div>
                </a>
              </li>
            ))}
          </ol>
        </div>
      </section>
    )}

    <!-- Section nav -->
    <section class="sections-nav">
      <div class="container">
        <div class="section-cards">
          <a href="/photography" class="section-card">
            <span class="section-card__eyebrow">Explore</span>
            <span class="section-card__label">Photography</span>
            <span class="section-card__desc">
              Street, travel, and landscape — shot on a Leica Q3. Also on glass.photo/lap.
            </span>
            <span class="section-card__arrow" aria-hidden="true">&rarr;</span>
          </a>
          <a href="/work" class="section-card">
            <span class="section-card__eyebrow">Background</span>
            <span class="section-card__label">Work</span>
            <span class="section-card__desc">
              Managing specialist Solutions Architects at AWS across security, networking, resilience, and migrations.
            </span>
            <span class="section-card__arrow" aria-hidden="true">&rarr;</span>
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Base>

<style>
  /* ---- Hero ---- */
  .hero {
    padding: 5rem 0 4.5rem;
  }

  .hero__inner {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 3rem;
    align-items: start;
  }

  .hero__avatar {
    padding-top: 0.75rem;
  }

  .hero__photo {
    width: 112px;
    height: 112px;
    border-radius: 50%;
    object-fit: cover;
    background: var(--color-surface);
    border: 2px solid var(--color-border);
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
  }

  .hero__name {
    font-size: clamp(3rem, 7vw, 5rem);
    font-weight: 300;
    margin: 0 0 1.25rem;
    letter-spacing: -0.025em;
    color: var(--color-text);
    font-style: italic;
    line-height: 0.95;
  }

  .hero__role {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin: 0 0 1.5rem;
    font-weight: 400;
    letter-spacing: 0.01em;
  }

  .hero__bio {
    font-size: 1.05rem;
    color: var(--color-text);
    max-width: 520px;
    margin: 0 0 2rem;
    line-height: 1.75;
    font-weight: 300;
  }

  .hero__links {
    display: flex;
    flex-wrap: wrap;
    gap: 0;
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid var(--color-border);
    padding-top: 1.25rem;
  }

  .hero__links li {
    display: contents;
  }

  .hero__links li + li .hero__link::before {
    content: '';
    display: inline-block;
    width: 1px;
    height: 0.9em;
    background: var(--color-border);
    margin: 0 0.9rem;
    vertical-align: middle;
    transform: translateY(-1px);
  }

  .hero__link {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-muted);
    transition: color 0.15s ease;
  }

  @media (hover: hover) {
    .hero__link:hover {
      color: var(--color-accent);
    }
  }

  /* ---- Writing ---- */
  .writing {
    padding: 3rem 0;
    border-top: 1px solid var(--color-border);
  }

  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 1.25rem;
  }

  .section-label {
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    margin: 0;
  }

  .section-more {
    font-size: 0.8rem;
    color: var(--color-accent);
    font-weight: 500;
  }

  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .post-item {
    border-top: 1px solid var(--color-border);
  }

  .post-card {
    display: grid;
    grid-template-columns: 88px 1fr;
    gap: 1rem;
    padding: 1rem 0;
    color: var(--color-text);
    align-items: start;
    transition: color 0.15s ease;
  }

  @media (hover: hover) {
    .post-card:hover .post-title {
      color: var(--color-accent);
    }
  }

  .post-thumb {
    width: 88px;
    height: 60px;
    border-radius: 0.25rem;
    overflow: hidden;
    background: var(--color-surface);
    flex-shrink: 0;
  }

  .post-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .post-body {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    min-width: 0;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .post-date {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    white-space: nowrap;
    font-variant-numeric: tabular-nums;
  }

  .post-cats {
    display: flex;
    gap: 0.35rem;
    list-style: none;
    padding: 0;
    margin: 0;
    flex-wrap: wrap;
  }

  .post-cat {
    font-size: 0.7rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    padding: 0.1rem 0.5rem;
    border-radius: 2rem;
    font-weight: 400;
    letter-spacing: 0.01em;
  }

  .post-title {
    font-weight: 500;
    font-size: 0.925rem;
    line-height: 1.4;
    transition: color 0.15s ease;
    margin: 0;
  }

  .post-desc {
    font-size: 0.82rem;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ---- Section cards ---- */
  .sections-nav {
    padding: 3rem 0 4rem;
    border-top: 1px solid var(--color-border);
  }

  .section-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .section-card {
    display: grid;
    grid-template-rows: auto auto 1fr auto;
    gap: 0.4rem;
    padding: 1.75rem 1.75rem 1.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    color: var(--color-text);
    transition: border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
    min-height: 180px;
    position: relative;
    overflow: hidden;
  }

  .section-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, transparent 60%, rgba(58, 99, 71, 0.06) 100%);
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  @media (hover: hover) {
    .section-card:hover {
      border-color: var(--color-accent);
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.07);
      color: var(--color-text);
    }

    .section-card:hover::before {
      opacity: 1;
    }
  }

  .section-card__eyebrow {
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
  }

  .section-card__label {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 1.6rem;
    font-style: italic;
    letter-spacing: -0.02em;
    line-height: 1;
    color: var(--color-text);
  }

  .section-card__desc {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    line-height: 1.55;
    align-self: end;
    margin-top: 0.25rem;
  }

  .section-card__arrow {
    font-size: 1rem;
    color: var(--color-accent);
    align-self: end;
    transition: transform 0.2s ease;
  }

  @media (hover: hover) {
    .section-card:hover .section-card__arrow {
      transform: translateX(3px);
    }
  }

  /* ---- Responsive ---- */
  @media (max-width: 640px) {
    .hero {
      padding: 3rem 0 3rem;
    }

    .hero__inner {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .hero__avatar {
      padding-top: 0;
    }

    .hero__name {
      font-size: clamp(2.5rem, 12vw, 4rem);
    }

    .section-cards {
      grid-template-columns: 1fr;
    }

    .post-card {
      grid-template-columns: 64px 1fr;
      gap: 0.75rem;
    }

    .post-thumb {
      width: 64px;
      height: 46px;
    }
  }
</style>
