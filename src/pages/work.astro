---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { spotlight, experience, talks, skillGroups } from '../data/work';
---

<Base
  title="Work"
  description="Mike Lapidakis — engineering leader, AWS, distributed systems."
>
  <Nav />

  <main>
    <section class="page-header">
      <div class="container">
        <p class="page-eyebrow">Background</p>
        <h1 class="page-title display">Work</h1>
        <p class="page-desc">
          I've spent the last decade building and leading specialist teams at AWS —
          growing organizations, stepping in during leadership transitions, and
          developing frameworks that outlast the moment. Currently leading Security
          &amp; Networking SAs across North America.
        </p>
      </div>
    </section>

    <!-- Spotlight -->
    <section class="work-section">
      <div class="container">
        <h2 class="section-label">Spotlight</h2>
        <div class="spotlight-grid">
          {spotlight.map(item => (
            <div class="spotlight-card">
              <span class="spotlight-type">{item.type}</span>
              <h3 class="spotlight-title display">{item.title}</h3>
              <p class="spotlight-desc">{item.desc}</p>
              <div class="spotlight-footer">
                <span class="spotlight-meta">{item.meta}</span>
                <div class="spotlight-links">
                  {item.links.map(link => (
                    <a href={link.href} target="_blank" rel="noopener" class="spotlight-link">
                      {link.label} →
                    </a>
                  ))}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Experience -->
    <section class="work-section">
      <div class="container">
        <h2 class="section-label">Experience</h2>
        <div class="experience-list">
          {experience.map(job => (
            <div class="job">
              <div class="job__header">
                <div>
                  <h3 class="job__company">{job.company}</h3>
                  <p class="job__role">{job.role}</p>
                </div>
                <div class="job__meta">
                  <time class="job__period">{job.period}</time>
                  <span class="job__location">{job.location}</span>
                </div>
              </div>
              <p class="job__desc">{job.description}</p>
              <ul class="job__tags">
                {job.tags.map(tag => (
                  <li class="tag">{tag}</li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Skills -->
    <section class="work-section">
      <div class="container">
        <h2 class="section-label">Skills &amp; Tools</h2>
        <div class="skill-groups">
          {skillGroups.map(group => (
            <div class="skill-group">
              <p class="skill-group__label">{group.label}</p>
              <ul class="skills-list">
                {group.skills.map(skill => (
                  <li class="tag">{skill}</li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    {talks.length > 0 && (
      <section class="work-section">
        <div class="container">
          <h2 class="section-label">Talks &amp; Writing</h2>
          <div class="talks-list">
            {talks.map(talk => (
              <div class="talk-item">
                <span class="talk-type">{talk.type}</span>
                <span class="talk-title">{talk.title}</span>
                {talk.desc && <p class="talk-desc">{talk.desc}</p>}
                <div class="talk-footer">
                  <span class="talk-meta">{talk.event} &middot; {talk.year}</span>
                  {talk.links.length > 0 && (
                    <div class="talk-links">
                      {talk.links.map(link => (
                        <a href={link.href} target="_blank" rel="noopener" class="talk-link">
                          {link.label} &rarr;
                        </a>
                      ))}
                    </div>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- Education -->
    <section class="work-section">
      <div class="container">
        <h2 class="section-label">Education</h2>
        <div class="job">
          <div class="job__header">
            <div>
              <h3 class="job__company">University of Toledo</h3>
              <p class="job__role">Bachelor of Science, Computer Science Engineering</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Contact -->
    <section class="work-section work-section--last">
      <div class="container">
        <h2 class="section-label">Get in Touch</h2>
        <p class="contact-text">
          Open to interesting conversations about cloud architecture, security,
          generative AI, and team leadership.
        </p>
        <div class="contact-links">
          <a href="https://linkedin.com/in/mikelapidakis" target="_blank" rel="noopener" class="contact-link">
            LinkedIn &rarr;
          </a>
          <a href="https://github.com/mlapidakis" target="_blank" rel="noopener" class="contact-link">
            GitHub &rarr;
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Base>

<style>
  .page-header {
    padding: 4.5rem 0 3rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 0;
  }

  .page-eyebrow {
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    margin: 0 0 0.75rem;
  }

  .page-title {
    font-size: clamp(2.75rem, 6vw, 4.25rem);
    font-weight: 300;
    font-style: italic;
    margin: 0 0 1rem;
    letter-spacing: -0.025em;
    line-height: 1;
  }

  .page-desc {
    font-size: 1rem;
    color: var(--color-text-muted);
    max-width: 480px;
    margin: 0;
    line-height: 1.65;
    font-weight: 300;
  }

  .work-section {
    padding: 2.75rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .work-section--last {
    padding-bottom: 4rem;
    border-bottom: none;
  }

  .section-label {
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    margin: 0 0 1.75rem;
  }

  /* Experience */
  .experience-list {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .job {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .job__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
  }

  .job__company {
    font-size: 1.05rem;
    font-weight: 500;
    margin: 0 0 0.2rem;
    letter-spacing: -0.01em;
  }

  .job__role {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin: 0;
  }

  .job__meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.15rem;
    flex-shrink: 0;
  }

  .job__period {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    white-space: nowrap;
    font-variant-numeric: tabular-nums;
  }

  .job__location {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    white-space: nowrap;
    opacity: 0.7;
  }

  .job__desc {
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--color-text);
    margin: 0;
    max-width: 620px;
    font-weight: 300;
  }

  .job__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  /* Tags */
  .tag {
    font-size: 0.75rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    padding: 0.2rem 0.65rem;
    border-radius: 2rem;
    font-weight: 400;
    letter-spacing: 0.01em;
  }

  /* Skills */
  .skill-groups {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .skill-group__label {
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin: 0 0 0.5rem;
    opacity: 0.7;
  }

  .skills-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  /* Talks */
  .talks-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .talk-item {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    color: var(--color-text);
    padding: 1.1rem 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: 0.4rem;
  }

  .talk-type {
    font-size: 0.65rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
  }

  .talk-title {
    font-weight: 500;
    font-size: 0.95rem;
  }

  .talk-desc {
    font-size: 0.82rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0;
  }

  .talk-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .talk-meta {
    font-size: 0.82rem;
    color: var(--color-text-muted);
  }

  .talk-links {
    display: flex;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .talk-link {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-accent);
    white-space: nowrap;
  }

  @media (hover: hover) {
    .talk-link:hover {
      color: var(--color-accent-hover);
    }
  }

  /* Contact */
  .contact-text {
    font-size: 1rem;
    color: var(--color-text);
    max-width: 440px;
    margin: 0 0 1.5rem;
    line-height: 1.65;
    font-weight: 300;
  }

  .contact-links {
    display: flex;
    gap: 1.5rem;
  }

  .contact-link {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-accent);
  }

  @media (hover: hover) {
    .contact-link:hover {
      color: var(--color-accent-hover);
    }
  }

  /* Spotlight */
  .spotlight-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .spotlight-card {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding: 1.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.4rem;
    color: var(--color-text);
    text-decoration: none;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    position: relative;
  }


  .spotlight-type {
    font-size: 0.65rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
  }

  .spotlight-title {
    font-size: 1.05rem;
    font-weight: 400;
    font-style: italic;
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin: 0;
    color: var(--color-text);
  }

  .spotlight-desc {
    font-size: 0.82rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0;
    flex-grow: 1;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .spotlight-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    margin-top: 0.25rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--color-border);
  }

  .spotlight-meta {
    font-size: 0.72rem;
    color: var(--color-text-muted);
    opacity: 0.8;
  }

  .spotlight-links {
    display: flex;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .spotlight-link {
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--color-accent);
    white-space: nowrap;
  }

  @media (max-width: 900px) {
    .spotlight-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 600px) {
    .spotlight-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 600px) {
    .page-header {
      padding: 3rem 0 2rem;
    }

    .job__header {
      flex-direction: column;
      gap: 0.25rem;
    }

    .job__meta {
      align-items: flex-start;
    }

    .contact-links {
      flex-direction: column;
      gap: 0.75rem;
    }
  }
</style>
