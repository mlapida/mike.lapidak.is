---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const experience = [
  {
    company: 'Amazon Web Services',
    role: 'Engineering Leader',
    period: '2019 – present',
    description: 'Leading engineering teams building developer experience and distributed systems products. Focus on platform reliability, developer productivity, and large-scale system design.',
    tags: ['Distributed Systems', 'Platform Engineering', 'Developer Experience', 'Team Leadership'],
  },
  {
    company: 'Previous Roles',
    role: 'Senior Engineering',
    period: 'Prior',
    description: 'Held senior engineering and leadership positions across B2B SaaS and startup environments. Built products across the stack with emphasis on backend systems and API design.',
    tags: ['SaaS', 'API Design', 'Backend Systems'],
  },
];

const talks = [
  // Add talks here as they happen
];

const skills = [
  'Distributed Systems', 'Platform Engineering', 'Team Leadership',
  'API Design', 'System Architecture', 'Developer Experience',
  'Go', 'TypeScript', 'Python', 'AWS', 'Kubernetes',
];
---

<Base
  title="Work"
  description="Mike Lapidakis — engineering leader, AWS, distributed systems."
>
  <Nav />

  <main>
    <section class="page-header">
      <div class="container">
        <h1 class="page-title">Work</h1>
        <p class="page-desc">
          Engineering leadership focused on developer experience, platform reliability,
          and building high-performing teams.
        </p>
      </div>
    </section>

    <!-- Experience -->
    <section class="work-section">
      <div class="container">
        <h2 class="section-label">Experience</h2>
        <div class="experience-list">
          {experience.map(job => (
            <div class="job">
              <div class="job__header">
                <div>
                  <h3 class="job__company">{job.company}</h3>
                  <p class="job__role">{job.role}</p>
                </div>
                <time class="job__period">{job.period}</time>
              </div>
              <p class="job__desc">{job.description}</p>
              <ul class="job__tags">
                {job.tags.map(tag => (
                  <li class="tag">{tag}</li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Skills -->
    <section class="work-section">
      <div class="container">
        <h2 class="section-label">Skills &amp; Tools</h2>
        <ul class="skills-list">
          {skills.map(skill => (
            <li class="tag">{skill}</li>
          ))}
        </ul>
      </div>
    </section>

    <!-- Talks (hidden when empty) -->
    {talks.length > 0 && (
      <section class="work-section">
        <div class="container">
          <h2 class="section-label">Talks &amp; Writing</h2>
          <div class="talks-list">
            {talks.map((talk: any) => (
              <a href={talk.href} target="_blank" rel="noopener" class="talk-item">
                <span class="talk-title">{talk.title}</span>
                <span class="talk-meta">{talk.event} &middot; {talk.year}</span>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- Contact -->
    <section class="work-section work-section--last">
      <div class="container">
        <h2 class="section-label">Get in Touch</h2>
        <p class="contact-text">
          Open to interesting conversations about engineering leadership,
          distributed systems, and developer tooling.
        </p>
        <div class="contact-links">
          <a href="https://linkedin.com/in/mikelapidakis" target="_blank" rel="noopener" class="contact-link">
            LinkedIn &rarr;
          </a>
          <a href="https://github.com/mlapidakis" target="_blank" rel="noopener" class="contact-link">
            GitHub &rarr;
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Base>

<style>
  .page-header {
    padding: 4rem 0 2.5rem;
  }

  .page-title {
    font-size: 2rem;
    font-weight: 700;
    margin: 0 0 0.75rem;
    letter-spacing: -0.02em;
  }

  .page-desc {
    font-size: 1rem;
    color: var(--color-text-muted);
    max-width: 520px;
    margin: 0;
    line-height: 1.6;
  }

  .work-section {
    padding: 2.5rem 0;
    border-top: 1px solid var(--color-border);
  }

  .work-section--last {
    padding-bottom: 4rem;
  }

  .section-label {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin: 0 0 1.5rem;
  }

  /* Experience */
  .experience-list {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .job {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .job__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
  }

  .job__company {
    font-size: 1.1rem;
    font-weight: 600;
    margin: 0 0 0.15rem;
  }

  .job__role {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin: 0;
  }

  .job__period {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .job__desc {
    font-size: 0.95rem;
    line-height: 1.65;
    color: var(--color-text);
    margin: 0;
    max-width: 640px;
  }

  .job__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  /* Tags */
  .tag {
    font-size: 0.78rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    padding: 0.2rem 0.6rem;
    border-radius: 2rem;
    font-weight: 500;
  }

  /* Skills */
  .skills-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  /* Talks */
  .talks-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .talk-item {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    color: var(--color-text);
    padding: 1rem;
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    transition: border-color 0.15s ease;
  }

  .talk-item:hover {
    border-color: var(--color-accent);
  }

  .talk-title {
    font-weight: 500;
  }

  .talk-meta {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  /* Contact */
  .contact-text {
    font-size: 1rem;
    color: var(--color-text);
    max-width: 480px;
    margin: 0 0 1.25rem;
    line-height: 1.6;
  }

  .contact-links {
    display: flex;
    gap: 1.5rem;
  }

  .contact-link {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-accent);
  }

  .contact-link:hover {
    color: var(--color-accent-hover);
  }

  @media (max-width: 600px) {
    .job__header {
      flex-direction: column;
    }

    .contact-links {
      flex-direction: column;
      gap: 0.75rem;
    }
  }
</style>
