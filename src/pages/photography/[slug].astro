---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';
import { collectionSlug } from './collection/[slug].astro';
import 'leaflet/dist/leaflet.css';

export async function getStaticPaths() {
  const allPhotos = (await getCollection('photos')).sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
  );

  return allPhotos.map((photo, index) => ({
    params: { slug: photo.id.replace(/\.md$/, '') },
    props: {
      photo,
      prev: index > 0 ? allPhotos[index - 1] : null,
      next: index < allPhotos.length - 1 ? allPhotos[index + 1] : null,
    },
  }));
}

const { photo, prev, next } = Astro.props;
const { title, date, location, gps, camera, lens, aperture, shutter, iso, image, collection } = photo.data;

const dateFormatted = date.toLocaleDateString('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
});

const dateISO = date.toISOString().split('T')[0];

const exifFields = [
  camera ? { label: 'Camera', value: camera } : null,
  lens ? { label: 'Lens', value: lens } : null,
  aperture ? { label: 'Aperture', value: `f/${aperture}` } : null,
  shutter ? { label: 'Shutter', value: shutter } : null,
  iso ? { label: 'ISO', value: String(iso) } : null,
].filter(Boolean) as { label: string; value: string }[];

const descParts = [location, dateFormatted];
if (camera) descParts.push(camera);
const description = `${title} — ${descParts.join(' · ')}`;

const siteUrl = 'https://mike.lapidak.is';
const imageAbsolute = new URL(image, siteUrl).toString();
const pageUrl = new URL(`/photography/${photo.id.replace(/\.md$/, '')}`, siteUrl).toString();

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Photograph',
  name: title,
  description: description,
  contentUrl: imageAbsolute,
  url: pageUrl,
  dateCreated: dateISO,
  locationCreated: {
    '@type': 'Place',
    name: location,
    ...(gps ? { geo: { '@type': 'GeoCoordinates', latitude: gps.lat, longitude: gps.lng } } : {}),
  },
  creator: {
    '@type': 'Person',
    name: 'Mike Lapidakis',
    url: siteUrl,
  },
  ...(camera ? { exifData: [{ '@type': 'PropertyValue', name: 'Camera', value: camera }] } : {}),
};
---

<Base title={title} description={description} image={image}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <Nav />

  <main class="photo-detail">
    <div class="photo-detail__layout">
      <!-- Photo panel -->
      <div class="photo-panel">
        <img
          src={image}
          alt={title}
          class="photo-detail__img"
          loading="eager"
          decoding="async"
        />
      </div>

      <!-- Metadata panel -->
      <aside class="meta-panel animate-fade-up">
        <!-- Breadcrumb -->
        <nav class="breadcrumb" aria-label="Back">
          <a
            href={collection ? `/photography/collection/${collectionSlug(collection)}` : '/photography'}
            class="breadcrumb__link"
          >
            <span aria-hidden="true">←</span>
            {collection ? collection : 'Photography'}
          </a>
        </nav>

        <!-- Title -->
        <h1 class="meta-title display">{title}</h1>

        <!-- Location + Date -->
        <p class="meta-location">
          <span>{location}</span>
          <span class="meta-sep">·</span>
          <span>{dateFormatted}</span>
        </p>

        <!-- EXIF -->
        {exifFields.length > 0 && (
          <div class="exif-grid">
            {exifFields.map(field => (
              <div class="exif-field">
                <span class="exif-label">{field.label}</span>
                <span class="exif-value">{field.value}</span>
              </div>
            ))}
          </div>
        )}

        <!-- GPS Map -->
        {gps && (
          <div
            id="photo-map"
            class="photo-map"
            data-lat={String(gps.lat)}
            data-lng={String(gps.lng)}
            aria-label={`Map of ${location}`}
          ></div>
        )}

        <!-- Prev / Next -->
        <nav class="photo-nav" aria-label="Adjacent photos">
          <div class="photo-nav__prev">
            {prev && (
              <a href={`/photography/${prev.id.replace(/\.md$/, '')}`} class="photo-nav__link">
                <span class="photo-nav__arrow">←</span>
                <span class="photo-nav__name">{prev.data.title}</span>
              </a>
            )}
          </div>
          <div class="photo-nav__next">
            {next && (
              <a href={`/photography/${next.id.replace(/\.md$/, '')}`} class="photo-nav__link photo-nav__link--next">
                <span class="photo-nav__name">{next.data.title}</span>
                <span class="photo-nav__arrow">→</span>
              </a>
            )}
          </div>
        </nav>
      </aside>
    </div>
  </main>

  <Footer />

  <script>
    import L from 'leaflet';

    const mapEl = document.getElementById('photo-map') as HTMLDivElement | null;
    if (mapEl) {
      const lat = parseFloat(mapEl.dataset.lat ?? '0');
      const lng = parseFloat(mapEl.dataset.lng ?? '0');

      const map = L.map(mapEl, {
        zoomControl: false,
        attributionControl: false,
        scrollWheelZoom: false,
        dragging: false,
        touchZoom: false,
        doubleClickZoom: false,
        boxZoom: false,
        keyboard: false,
      }).setView([lat, lng], 13);

      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);

      L.circleMarker([lat, lng], {
        radius: 6,
        fillColor: '#3a6347',
        fillOpacity: 1,
        color: '#fff',
        weight: 2,
      }).addTo(map);
    }
  </script>
</Base>

<style>
  .photo-detail {
    min-height: calc(100vh - 64px);
    padding-top: 64px; /* nav height */
  }

  .photo-detail__layout {
    display: grid;
    grid-template-columns: 60fr 40fr;
    min-height: calc(100vh - 64px);
  }

  /* ── Photo panel ── */
  .photo-panel {
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-surface);
    padding: 2rem;
    overflow: hidden;
  }

  .photo-detail__img {
    max-height: 90vh;
    max-width: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    display: block;
    box-shadow: 0 8px 48px rgba(0, 0, 0, 0.18);
  }

  /* ── Metadata panel ── */
  .meta-panel {
    padding: 3rem 2.5rem 3rem;
    border-left: 1px solid var(--color-border);
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  /* Breadcrumb */
  .breadcrumb__link {
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    font-size: 0.8rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  @media (hover: hover) {
    .breadcrumb__link:hover {
      color: var(--color-accent);
    }
  }

  /* Title */
  .meta-title {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 400;
    font-style: italic;
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin: 0;
    color: var(--color-text);
  }

  /* Location */
  .meta-location {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin: 0;
    display: flex;
    align-items: center;
    gap: 0.5em;
    flex-wrap: wrap;
  }

  .meta-sep {
    opacity: 0.4;
  }

  /* EXIF grid */
  .exif-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem 1.5rem;
    padding-top: 0.5rem;
    border-top: 1px solid var(--color-border);
  }

  .exif-field {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .exif-label {
    font-size: 0.65rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
  }

  .exif-value {
    font-size: 0.875rem;
    color: var(--color-text);
    font-weight: 400;
  }

  /* Map */
  .photo-map {
    height: 200px;
    border-radius: 0.5rem;
    overflow: hidden;
    border: 1px solid var(--color-border);
  }

  /* Prev/Next nav */
  .photo-nav {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    padding-top: 0.5rem;
    border-top: 1px solid var(--color-border);
    margin-top: auto;
  }

  .photo-nav__prev,
  .photo-nav__next {
    flex: 1;
  }

  .photo-nav__next {
    text-align: right;
  }

  .photo-nav__link {
    display: inline-flex;
    align-items: center;
    gap: 0.35em;
    font-size: 0.8rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.15s ease;
    line-height: 1.4;
  }

  @media (hover: hover) {
    .photo-nav__link:hover {
      color: var(--color-accent);
    }
  }

  .photo-nav__arrow {
    flex-shrink: 0;
    opacity: 0.6;
  }

  .photo-nav__name {
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .photo-detail {
      padding-top: 56px;
    }

    .photo-detail__layout {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .photo-panel {
      padding: 1rem;
      background: #000;
    }

    .photo-detail__img {
      max-height: 60vh;
      box-shadow: none;
    }

    .meta-panel {
      border-left: none;
      border-top: 1px solid var(--color-border);
      padding: 2rem 1.5rem;
      gap: 1.25rem;
    }
  }
</style>
