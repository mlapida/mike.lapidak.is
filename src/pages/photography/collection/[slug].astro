---
import Base from '../../../layouts/Base.astro';
import Nav from '../../../components/Nav.astro';
import Footer from '../../../components/Footer.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

export function collectionSlug(name: string) {
  return name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
}

export async function getStaticPaths() {
  const allPhotos = await getCollection('photos');

  const collectionMap = new Map<string, typeof allPhotos>();
  for (const photo of allPhotos) {
    if (!photo.data.collection) continue;
    const key = photo.data.collection;
    if (!collectionMap.has(key)) collectionMap.set(key, []);
    collectionMap.get(key)!.push(photo);
  }

  return [...collectionMap.entries()].map(([name, photos]) => ({
    params: { slug: collectionSlug(name) },
    props: {
      name,
      photos: photos.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()),
    },
  }));
}

const { name, photos } = Astro.props;
---

<Base
  title={name}
  description={`${name} — a photo collection by Mike Lapidakis`}
>
  <Nav />

  <main>
    <section class="page-header">
      <div class="container">
        <nav class="breadcrumb">
          <a href="/photography" class="breadcrumb__link">
            <span aria-hidden="true">←</span> Photography
          </a>
        </nav>
        <p class="page-eyebrow">Collection</p>
        <h1 class="page-title display">{name}</h1>
        <p class="page-desc">{photos.length} photo{photos.length !== 1 ? 's' : ''}</p>
      </div>
    </section>

    <div class="gallery-wrapper">
      <div class="container--wide">
        <div class="photo-grid">
          {photos.map((photo, i) => {
            const aspect = photo.data.imgWidth && photo.data.imgHeight
              ? photo.data.imgWidth / photo.data.imgHeight
              : photo.data.orientation === 'portrait' ? 2/3 : 3/2;
            return (
              <a
                href={`/photography/${photo.id.replace(/\.md$/, '')}`}
                class="photo-item"
                data-aspect={aspect.toFixed(4)}
                aria-label={photo.data.title}
              >
                <Image
                  src={photo.data.image}
                  alt={photo.data.title}
                  width={900}
                  height={Math.round(900 / ((photo.data.imgWidth ?? 3) / (photo.data.imgHeight ?? 2)))}
                  loading={i < 3 ? 'eager' : 'lazy'}
                  decoding="async"
                  class="photo-thumb"
                  quality={85}
                />
                <div class="photo-overlay">
                  <span class="photo-title">{photo.data.title}</span>
                  <span class="photo-location">{photo.data.location}</span>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </div>
  </main>

  <Footer />

  <script>
    function justify(grid: HTMLElement, targetH = 280, gap = 8) {
      const items = Array.from(grid.querySelectorAll<HTMLElement>('.photo-item'));
      if (!items.length) return;
      const W = grid.clientWidth;

      type Item = { el: HTMLElement; a: number };
      const rows: Item[][] = [];
      let row: Item[] = [];
      let rowW = 0;

      for (const el of items) {
        const a = parseFloat(el.dataset.aspect ?? '1.5');
        const photoW = targetH * a;
        const extra = row.length > 0 ? gap : 0;
        if (row.length > 0 && rowW + extra + photoW > W) {
          rows.push(row);
          row = [{ el, a }];
          rowW = photoW;
        } else {
          row.push({ el, a });
          rowW += extra + photoW;
        }
      }
      if (row.length) rows.push(row);

      for (let ri = 0; ri < rows.length; ri++) {
        const r = rows[ri];
        const isLast = ri === rows.length - 1;
        const sumA = r.reduce((s, x) => s + x.a, 0);
        const rowH = isLast ? targetH : (W - gap * (r.length - 1)) / sumA;
        for (const { el, a } of r) {
          el.style.width = `${a * rowH}px`;
          el.style.height = `${rowH}px`;
          el.style.flexGrow = '0';
        }
      }
    }

    function runAll() {
      document.querySelectorAll<HTMLElement>('.photo-grid').forEach(g => justify(g));
    }

    runAll();

    let t: ReturnType<typeof setTimeout>;
    window.addEventListener('resize', () => { clearTimeout(t); t = setTimeout(runAll, 100); });
  </script>
</Base>

<style>
  .page-header {
    padding: 4.5rem 0 3rem;
    border-bottom: 1px solid var(--color-border);
  }

  .breadcrumb {
    margin-bottom: 1.5rem;
  }

  .breadcrumb__link {
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    font-size: 0.8rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  @media (hover: hover) {
    .breadcrumb__link:hover {
      color: var(--color-accent);
    }
  }

  .page-eyebrow {
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    margin: 0 0 0.75rem;
  }

  .page-title {
    font-size: clamp(2.75rem, 6vw, 4.25rem);
    font-weight: 300;
    font-style: italic;
    margin: 0 0 0.5rem;
    letter-spacing: -0.025em;
    line-height: 1;
  }

  .page-desc {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin: 0;
    font-weight: 300;
  }

  .gallery-wrapper {
    padding: 2.5rem 0 4rem;
  }

  /* ── Justified row grid ── */
  .photo-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: flex-start;
  }

  .photo-item {
    display: block;
    position: relative;
    overflow: hidden;
    background: var(--color-surface);
    flex-shrink: 0;
    height: 280px;
    flex-grow: 1;
  }

  .photo-thumb {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  @media (hover: hover) {
    .photo-item:hover .photo-thumb {
      transform: scale(1.04);
    }
  }

  .photo-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, transparent 55%);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 1rem;
    opacity: 0;
    transition: opacity 0.25s ease;
    pointer-events: none;
  }

  @media (hover: hover) {
    .photo-item:hover .photo-overlay {
      opacity: 1;
    }
  }

  .photo-title {
    color: #fff;
    font-weight: 500;
    font-size: 0.875rem;
    line-height: 1.3;
  }

  .photo-location {
    color: rgba(255,255,255,0.65);
    font-size: 0.75rem;
    margin-top: 0.2rem;
  }

</style>
