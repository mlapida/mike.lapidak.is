---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';
import { collectionSlug } from './photography/collection/[slug].astro';
import { Image } from 'astro:assets';

const allPhotos = (await getCollection('photos')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

// Group into collections (preserving sort order within each group)
const collectionMap = new Map<string, typeof allPhotos>();
const uncollected: typeof allPhotos = [];

for (const photo of allPhotos) {
  if (photo.data.collection) {
    const key = photo.data.collection;
    if (!collectionMap.has(key)) collectionMap.set(key, []);
    collectionMap.get(key)!.push(photo);
  } else {
    uncollected.push(photo);
  }
}

const collections = [...collectionMap.entries()].sort(
  (a, b) => b[1][0].data.date.valueOf() - a[1][0].data.date.valueOf()
);
---

<Base
  title="Photography"
  description="Photos by Mike Lapidakis — street, travel, and landscape."
>
  <Nav />

  <main>
    <section class="page-header">
      <div class="container">
        <p class="page-eyebrow">Portfolio</p>
        <h1 class="page-title display">Photography</h1>
        <p class="page-desc">
          Street, travel, and aerial photography.
          More on <a href="https://glass.photo/lap" target="_blank" rel="noopener">glass.photo/lap</a>.
        </p>
      </div>
    </section>

    {allPhotos.length === 0 ? (
      <div class="container">
        <p class="empty-state">No photos yet — add some in <code>src/content/photos/</code>.</p>
      </div>
    ) : (
      <div class="gallery-wrapper">

        {/* ── Collections ── */}
        {collections.length > 0 && (
          <section class="gallery-section">
            <div class="container--wide">
              <div class="section-label">
                <span class="section-eyebrow">Collections</span>
              </div>
              <div class="collection-cards">
                {collections.map(([name, photos]) => {
                  const stackPhotos = photos.slice(0, 3);
                  return (
                    <a
                      href={`/photography/collection/${collectionSlug(name)}`}
                      class="collection-card"
                      aria-label={name}
                    >
                      <div class="stack-wrap">
                        {stackPhotos.slice().reverse().map((photo, i) => (
                          <Image
                            src={photo.data.image}
                            alt=""
                            class={`stack-img stack-img--${i}`}
                            width={400}
                            height={Math.round(400 / ((photo.data.imgWidth ?? 4) / (photo.data.imgHeight ?? 3)))}
                            loading="eager"
                            decoding="async"
                            quality={85}
                          />
                        ))}
                      </div>
                      <div class="card-info">
                        <span class="card-eyebrow">Collection</span>
                        <h2 class="card-title display">{name}</h2>
                        <span class="card-count">{photos.length} photo{photos.length !== 1 ? 's' : ''}</span>
                        <span class="card-arrow">View collection →</span>
                      </div>
                    </a>
                  );
                })}
              </div>
            </div>
          </section>
        )}

        {/* ── Singles ── */}
        {uncollected.length > 0 && (
          <section class="gallery-section">
            <div class="container--wide">
              {collections.length > 0 && (
                <div class="section-label">
                  <span class="section-eyebrow">Singles</span>
                </div>
              )}
              <div class="photo-grid">
                {uncollected.map((photo, i) => {
                  const aspect = photo.data.imgWidth && photo.data.imgHeight
                    ? photo.data.imgWidth / photo.data.imgHeight
                    : photo.data.orientation === 'portrait' ? 2/3 : 3/2;
                  return (
                    <a
                      href={`/photography/${photo.id.replace(/\.md$/, '')}`}
                      class="photo-item"
                      data-aspect={aspect.toFixed(4)}
                      aria-label={photo.data.title}
                    >
                      <Image
                        src={photo.data.image}
                        alt={photo.data.title}
                        width={900}
                        height={Math.round(900 / ((photo.data.imgWidth ?? 3) / (photo.data.imgHeight ?? 2)))}
                        loading={i < 3 ? 'eager' : 'lazy'}
                        decoding="async"
                        class="photo-thumb"
                        quality={85}
                      />
                      <div class="photo-overlay">
                        <span class="photo-title">{photo.data.title}</span>
                        <span class="photo-location">{photo.data.location}</span>
                      </div>
                    </a>
                  );
                })}
              </div>
            </div>
          </section>
        )}

      </div>
    )}
  </main>

  <Footer />

  <script>
    function justify(grid: HTMLElement, targetH = 280, gap = 8) {
      const items = Array.from(grid.querySelectorAll<HTMLElement>('.photo-item'));
      if (!items.length) return;
      const W = grid.clientWidth;

      // Greedy row packing at target height
      type Item = { el: HTMLElement; a: number };
      const rows: Item[][] = [];
      let row: Item[] = [];
      let rowW = 0;

      for (const el of items) {
        const a = parseFloat(el.dataset.aspect ?? '1.5');
        const photoW = targetH * a;
        const extra = row.length > 0 ? gap : 0;
        if (row.length > 0 && rowW + extra + photoW > W) {
          rows.push(row);
          row = [{ el, a }];
          rowW = photoW;
        } else {
          row.push({ el, a });
          rowW += extra + photoW;
        }
      }
      if (row.length) rows.push(row);

      // Apply exact dimensions per row
      for (let ri = 0; ri < rows.length; ri++) {
        const r = rows[ri];
        const isLast = ri === rows.length - 1;
        const sumA = r.reduce((s, x) => s + x.a, 0);
        // Last row: don't scale up, keep target height
        const rowH = isLast
          ? targetH
          : (W - gap * (r.length - 1)) / sumA;
        for (const { el, a } of r) {
          el.style.width = `${a * rowH}px`;
          el.style.height = `${rowH}px`;
          el.style.flexGrow = '0';
        }
      }
    }

    function runAll() {
      document.querySelectorAll<HTMLElement>('.photo-grid').forEach(g => justify(g));
    }

    runAll();

    let t: ReturnType<typeof setTimeout>;
    window.addEventListener('resize', () => { clearTimeout(t); t = setTimeout(runAll, 100); });
  </script>
</Base>

<style>
  .page-header {
    padding: 4.5rem 0 3rem;
    border-bottom: 1px solid var(--color-border);
  }

  .page-eyebrow {
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    margin: 0 0 0.75rem;
  }

  .page-title {
    font-size: clamp(2.75rem, 6vw, 4.25rem);
    font-weight: 300;
    font-style: italic;
    margin: 0 0 1rem;
    letter-spacing: -0.025em;
    line-height: 1;
  }

  .page-desc {
    font-size: 1rem;
    color: var(--color-text-muted);
    max-width: 480px;
    margin: 0;
    line-height: 1.65;
    font-weight: 300;
  }

  .empty-state {
    padding: 4rem 0;
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }

  .gallery-wrapper {
    padding-bottom: 5rem;
  }

  .gallery-section {
    padding: 2.5rem 0 0;
  }

  .section-label {
    margin-bottom: 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--color-border);
  }

  .section-eyebrow {
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
  }

  /* ── Collection cards ── */
  .collection-cards {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
  }

  .collection-card {
    display: flex;
    align-items: center;
    gap: 1.75rem;
    padding: 1.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    text-decoration: none;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  @media (hover: hover) {
    .collection-card:hover {
      border-color: var(--color-accent);
      box-shadow: 0 4px 24px rgba(0, 0, 0, 0.07);
    }
  }

  /* Photo stack */
  .stack-wrap {
    position: relative;
    width: 130px;
    height: 90px;
    flex-shrink: 0;
  }

  .stack-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border: 2px solid #fff;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.18);
    transform-origin: center bottom;
  }

  /* back → front: index 0 = back (first rendered), index 2 = front */
  .stack-img--0 { transform: rotate(-5deg) translate(-6px, -3px); z-index: 1; }
  .stack-img--1 { transform: rotate(-2deg) translate(-2px, -1px); z-index: 2; }
  .stack-img--2 { transform: rotate(0deg);                        z-index: 3; }

  @media (hover: hover) {
    .collection-card:hover .stack-img--0 { transform: rotate(-8deg) translate(-10px, -2px); }
    .collection-card:hover .stack-img--1 { transform: rotate(-3deg) translate(-4px, -1px); }
    .collection-card:hover .stack-img--2 { transform: rotate(1deg); }
  }

  /* Card info */
  .card-info {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .card-eyebrow {
    font-size: 0.65rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
  }

  .card-title {
    font-size: 1.2rem;
    font-weight: 400;
    font-style: italic;
    letter-spacing: -0.02em;
    color: var(--color-text);
    margin: 0;
    line-height: 1.2;
  }

  .card-count {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-top: 0.1rem;
  }

  .card-arrow {
    font-size: 0.78rem;
    color: var(--color-accent);
    margin-top: 0.5rem;
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  @media (hover: hover) {
    .collection-card:hover .card-arrow {
      opacity: 1;
      transform: translateX(0);
    }
  }

  /* ── Justified row grid ── */
  .photo-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: flex-start;
  }

  .photo-item {
    display: block;
    position: relative;
    overflow: hidden;
    background: var(--color-surface);
    flex-shrink: 0;
    /* JS sets width + height; fallback keeps things visible */
    height: 280px;
    flex-grow: 1;
  }

  .photo-thumb {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  @media (hover: hover) {
    .photo-item:hover .photo-thumb {
      transform: scale(1.03);
    }
  }

  .photo-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, transparent 55%);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 1rem;
    opacity: 0;
    transition: opacity 0.25s ease;
    pointer-events: none;
  }

  @media (hover: hover) {
    .photo-item:hover .photo-overlay {
      opacity: 1;
    }
  }

  .photo-title {
    color: #fff;
    font-weight: 500;
    font-size: 0.875rem;
    line-height: 1.3;
  }

  .photo-location {
    color: rgba(255,255,255,0.65);
    font-size: 0.75rem;
    margin-top: 0.2rem;
  }

  @media (max-width: 900px) {
    .collection-cards { grid-template-columns: 1fr; }
  }
</style>
