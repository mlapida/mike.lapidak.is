---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const allPhotos = (await getCollection('photos')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const gpsPhotos = allPhotos.filter(p => p.data.gps);

// Serialize metadata for client scripts
const photoMeta = allPhotos.map((p, i) => ({
  idx: i,
  title: p.data.title,
  date: p.data.date.toISOString().slice(0, 10),
  location: p.data.location,
  camera: p.data.camera ?? null,
  lens: p.data.lens ?? null,
  aperture: p.data.aperture ?? null,
  shutter: p.data.shutter ?? null,
  iso: p.data.iso ?? null,
  image: p.data.image,
}));

const mapPoints = gpsPhotos.map(p => ({
  title: p.data.title,
  location: p.data.location,
  lat: p.data.gps!.lat,
  lng: p.data.gps!.lng,
  image: p.data.image,
}));

const hasMap = gpsPhotos.length > 0;
---

<Base
  title="Photography"
  description="Photos by Mike Lapidakis — landscapes, street, and travel."
>
  <Nav />

  <main>
    <section class="page-header">
      <div class="container">
        <h1 class="page-title">Photography</h1>
        <p class="page-desc">
          Landscapes, street scenes, and moments from travels.
          Shot mostly on Sony mirrorless with prime lenses.
        </p>
      </div>
    </section>

    {allPhotos.length === 0 ? (
      <div class="container">
        <p class="empty-state">
          No photos yet — add some in <code>src/content/photos/</code>.
        </p>
      </div>
    ) : (
      <>
        <!-- Photo grid -->
        <section class="gallery-section">
          <div class="container--wide">
            <div class="photo-grid" id="gallery">
              {allPhotos.map((photo, i) => (
                <a
                  href={photo.data.image}
                  class="photo-item"
                  data-pswp-width="1920"
                  data-pswp-height="1280"
                  data-index={String(i)}
                  aria-label={photo.data.title}
                >
                  <img
                    src={photo.data.image}
                    alt={photo.data.title}
                    loading={i < 6 ? 'eager' : 'lazy'}
                    class="photo-thumb"
                  />
                  <div class="photo-overlay">
                    <span class="photo-title">{photo.data.title}</span>
                    <span class="photo-location">{photo.data.location}</span>
                  </div>
                </a>
              ))}
            </div>
          </div>
        </section>

        <!-- Map section -->
        {hasMap && (
          <section class="map-section">
            <div class="container">
              <h2 class="section-label">Locations</h2>
              <div id="photo-map" class="map-container"></div>
            </div>
          </section>
        )}
      </>
    )}
  </main>

  <Footer />
</Base>

<!-- Embed metadata as JSON for scripts -->
<script type="application/json" id="photo-meta-json" set:text={JSON.stringify(photoMeta)} />
{hasMap && <script type="application/json" id="map-points-json" set:text={JSON.stringify(mapPoints)} />}

<!-- PhotoSwipe -->
<script>
  import PhotoSwipeLightbox from 'photoswipe/lightbox';
  import 'photoswipe/style.css';

  interface PhotoMeta {
    idx: number;
    title: string;
    date: string;
    location: string;
    camera: string | null;
    lens: string | null;
    aperture: string | null;
    shutter: string | null;
    iso: number | null;
    image: string;
  }

  const metaRaw = document.getElementById('photo-meta-json')?.textContent ?? '[]';
  const allMeta: PhotoMeta[] = JSON.parse(metaRaw);

  const lightbox = new PhotoSwipeLightbox({
    gallery: '#gallery',
    children: 'a',
    pswpModule: () => import('photoswipe'),
    padding: { top: 20, bottom: 80, left: 20, right: 20 },
  });

  // Build EXIF caption bar
  lightbox.on('change', () => {
    const el = lightbox.pswp?.currSlide?.data.element as HTMLElement | undefined;
    const idx = el ? parseInt(el.dataset.index ?? '0', 10) : 0;
    const meta = allMeta[idx];
    const bar = document.getElementById('pswp-caption');
    if (!bar || !meta) return;

    const exif: string[] = [];
    if (meta.camera) exif.push(meta.camera);
    if (meta.lens) exif.push(meta.lens);
    if (meta.aperture) exif.push(`f/${meta.aperture}`);
    if (meta.shutter) exif.push(meta.shutter);
    if (meta.iso) exif.push(`ISO ${meta.iso}`);

    bar.innerHTML = `
      <span class="pswp-caption__title">${meta.title}</span>
      <span class="pswp-caption__meta">
        ${meta.location}${exif.length ? ' &middot; ' + exif.join(' &middot; ') : ''}
      </span>
    `;
    bar.hidden = false;
  });

  lightbox.on('close', () => {
    const bar = document.getElementById('pswp-caption');
    if (bar) bar.hidden = true;
  });

  lightbox.init();
</script>

<!-- Leaflet map -->
<script>
  const mapEl = document.getElementById('photo-map');
  const pointsEl = document.getElementById('map-points-json');
  if (mapEl && pointsEl) {
    interface MapPoint { title: string; location: string; lat: number; lng: number; image: string; }
    const points: MapPoint[] = JSON.parse(pointsEl.textContent ?? '[]');

    Promise.all([
      import('leaflet'),
      // @ts-ignore — CSS module
      import('leaflet/dist/leaflet.css'),
    ]).then(([{ default: L }]) => {
      const map = L.map('photo-map');

      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
        maxZoom: 18,
      }).addTo(map);

      const markers = points.map(p => {
        const m = L.marker([p.lat, p.lng]);
        m.bindPopup(`
          <div class="map-popup">
            <img src="${p.image}" alt="${p.title}" class="map-popup__img" />
            <div class="map-popup__info">
              <strong>${p.title}</strong>
              <span>${p.location}</span>
            </div>
          </div>
        `);
        return m;
      });

      markers.forEach(m => m.addTo(map));

      if (points.length > 1) {
        const group = L.featureGroup(markers);
        map.fitBounds(group.getBounds(), { padding: [40, 40] });
      } else if (points.length === 1) {
        map.setView([points[0].lat, points[0].lng], 8);
      }
    });
  }
</script>

<!-- Caption bar element (lives outside PhotoSwipe pswp root) -->
<div id="pswp-caption" class="pswp-caption" hidden></div>

<style>
  .page-header {
    padding: 4rem 0 2.5rem;
  }

  .page-title {
    font-size: 2rem;
    font-weight: 700;
    margin: 0 0 0.75rem;
    letter-spacing: -0.02em;
  }

  .page-desc {
    font-size: 1rem;
    color: var(--color-text-muted);
    max-width: 520px;
    margin: 0;
    line-height: 1.6;
  }

  .empty-state {
    padding: 4rem 0;
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }

  .empty-state code {
    background: var(--color-surface);
    padding: 0.1em 0.4em;
    border-radius: 3px;
    font-size: 0.9em;
  }

  /* Photo grid */
  .gallery-section {
    padding-bottom: 3rem;
  }

  .photo-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 0.5rem;
  }

  .photo-item {
    position: relative;
    display: block;
    aspect-ratio: 3 / 2;
    overflow: hidden;
    background: var(--color-surface);
    cursor: zoom-in;
  }

  .photo-thumb {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.35s ease;
    display: block;
  }

  .photo-item:hover .photo-thumb {
    transform: scale(1.04);
  }

  .photo-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, transparent 55%);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 1rem;
    opacity: 0;
    transition: opacity 0.25s ease;
  }

  .photo-item:hover .photo-overlay {
    opacity: 1;
  }

  .photo-title {
    color: #fff;
    font-weight: 600;
    font-size: 0.9rem;
    line-height: 1.3;
  }

  .photo-location {
    color: rgba(255,255,255,0.72);
    font-size: 0.78rem;
    margin-top: 0.2rem;
  }

  /* Section label */
  .section-label {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin: 0 0 1rem;
  }

  /* Map */
  .map-section {
    padding: 3rem 0;
    border-top: 1px solid var(--color-border);
  }

  .map-container {
    height: 420px;
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    overflow: hidden;
  }

  /* Leaflet popup */
  :global(.map-popup) {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    min-width: 160px;
  }

  :global(.map-popup__img) {
    width: 100%;
    height: 100px;
    object-fit: cover;
    border-radius: 4px;
  }

  :global(.map-popup__info) {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    font-size: 0.85rem;
  }

  :global(.map-popup__info span) {
    color: #666;
    font-size: 0.8rem;
  }

  /* PhotoSwipe caption bar */
  .pswp-caption {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 9999;
    background: linear-gradient(to top, rgba(0,0,0,0.75), transparent);
    padding: 2rem 2rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    pointer-events: none;
  }

  :global(.pswp-caption__title) {
    color: #fff;
    font-weight: 600;
    font-size: 0.95rem;
  }

  :global(.pswp-caption__meta) {
    color: rgba(255,255,255,0.65);
    font-size: 0.8rem;
  }
</style>
