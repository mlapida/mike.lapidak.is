---
const links = [
  { href: '/', label: 'Home' },
  { href: '/photography', label: 'Photography' },
  { href: '/work', label: 'Work' },
];

const current = Astro.url.pathname;
---
<nav class="nav">
  <div class="container">
    <div class="nav__inner">
      <a href="/" class="nav__brand" aria-label="Mike Lapidakis — home">
        <span class="nav__brand-mark">ML</span>
      </a>
      <ul class="nav__links" role="list">
        {links.map(link => {
          const isActive = current === link.href || (link.href !== '/' && current.startsWith(link.href));
          return (
            <li>
              <a href={link.href} class:list={['nav__link', { 'nav__link--active': isActive }]}>
                {link.label}
                {isActive && <span class="nav__link-dot" aria-hidden="true" />}
              </a>
            </li>
          );
        })}
      </ul>
    </div>
  </div>
</nav>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: var(--color-bg-glass);
    border-bottom: 1px solid var(--color-border);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    padding-top: env(safe-area-inset-top, 0px);
  }

  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 3.25rem;
  }

  .nav__brand {
    display: flex;
    align-items: center;
  }


  .nav__brand-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-weight: 400;
    font-style: italic;
    font-size: 0.95rem;
    letter-spacing: -0.01em;
    font-optical-sizing: auto;
    color: var(--color-bg);
    background: var(--color-text);
    width: 2rem;
    height: 2rem;
    border-radius: 0.25rem;
    transition: background-color 0.15s ease;
  }

  @media (hover: hover) {
    .nav__brand:hover .nav__brand-mark {
      background-color: var(--color-accent);
    }
  }

  .nav__links {
    display: flex;
    gap: 0.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav__link {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.875rem;
    font-weight: 400;
    color: var(--color-text-muted);
    letter-spacing: 0.01em;
    padding: 0.35rem 0.6rem;
    border-radius: 0.3rem;
    transition: color 0.15s ease, background-color 0.15s ease;
  }

  @media (hover: hover) {
    .nav__link:hover {
      color: var(--color-text);
      background-color: var(--color-surface);
    }
  }

  .nav__link--active {
    color: var(--color-text);
    font-weight: 500;
  }

  .nav__link-dot {
    display: inline-block;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--color-accent);
    flex-shrink: 0;
  }
</style>
