---
const links = [
  { href: '/', label: 'Home' },
  { href: '/photography', label: 'Photography' },
  { href: '/work', label: 'Work' },
];

const current = Astro.url.pathname;
---
<nav class="nav">
  <div class="nav__safe-fill"></div>
  <div class="nav__bar">
  <div class="container">
    <div class="nav__inner">
      <a href="/" class="nav__brand" aria-label="Mike Lapidakis — home">
        <span class="nav__brand-mark">ML</span>
      </a>
      <ul class="nav__links" role="list">
        {links.map(link => {
          const isActive = current === link.href || (link.href !== '/' && current.startsWith(link.href));
          return (
            <li>
              <a href={link.href} class:list={['nav__link', { 'nav__link--active': isActive }]}>
                {link.label}
                {isActive && <span class="nav__link-dot" aria-hidden="true" />}
              </a>
            </li>
          );
        })}
      </ul>
      <button class="nav__theme-toggle" id="theme-toggle" aria-label="Toggle dark mode">
        <!-- Moon icon — shown in light mode -->
        <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
        <!-- Sun icon — shown in dark mode -->
        <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="5"/>
          <line x1="12" y1="1" x2="12" y2="3"/>
          <line x1="12" y1="21" x2="12" y2="23"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="1" y1="12" x2="3" y2="12"/>
          <line x1="21" y1="12" x2="23" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
      </button>
    </div>
  </div>
  </div>
</nav>

<script>
  const btn = document.getElementById('theme-toggle');
  const html = document.documentElement;

  function getTheme(): string {
    return html.getAttribute('data-theme') ?? 'light';
  }

  function setTheme(theme: string) {
    html.setAttribute('data-theme', theme);
    localStorage.setItem('theme-preference', theme);
  }

  if (btn) {
    btn.addEventListener('click', () => {
      setTheme(getTheme() === 'dark' ? 'light' : 'dark');
    });
  }

  // Re-sync if system preference changes and user has no stored override
  window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
    if (!localStorage.getItem('theme-preference')) {
      html.setAttribute('data-theme', e.matches ? 'dark' : 'light');
    }
  });
</script>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
  }

  /* Solid fill for the safe-area inset (beside Dynamic Island / notch).
     Kept as a real element — separate from the blurred glass layer below
     so backdrop-filter cannot bleed page content through it. */
  .nav__safe-fill {
    height: env(safe-area-inset-top, 0px);
    background-color: var(--color-bg);
  }

  .nav__bar {
    background-color: var(--color-bg-glass);
    border-bottom: 1px solid var(--color-border);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 3.25rem;
  }

  .nav__brand {
    display: flex;
    align-items: center;
  }


  .nav__brand-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-weight: 400;
    font-style: italic;
    font-size: 0.95rem;
    letter-spacing: -0.01em;
    font-optical-sizing: auto;
    color: var(--color-bg);
    background: var(--color-text);
    width: 2rem;
    height: 2rem;
    border-radius: 0.25rem;
    transition: background-color 0.15s ease;
  }

  @media (hover: hover) {
    .nav__brand:hover .nav__brand-mark {
      background-color: var(--color-accent);
    }
  }

  .nav__links {
    display: flex;
    gap: 0.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav__link {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.875rem;
    font-weight: 400;
    color: var(--color-text-muted);
    letter-spacing: 0.01em;
    padding: 0.35rem 0.6rem;
    border-radius: 0.3rem;
    transition: color 0.15s ease, background-color 0.15s ease;
  }

  @media (hover: hover) {
    .nav__link:hover {
      color: var(--color-text);
      background-color: var(--color-surface);
    }
  }

  .nav__link--active {
    color: var(--color-text);
    font-weight: 500;
  }

  .nav__link-dot {
    display: inline-block;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--color-accent);
    flex-shrink: 0;
  }

  .nav__theme-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border: none;
    background: transparent;
    color: var(--color-text-muted);
    border-radius: 0.3rem;
    cursor: pointer;
    transition: color 0.15s ease, background-color 0.15s ease;
    flex-shrink: 0;
    margin-left: 0.25rem;
  }

  @media (hover: hover) {
    .nav__theme-toggle:hover {
      color: var(--color-text);
      background-color: var(--color-surface);
    }
  }

  .icon-sun {
    display: none;
  }

  :global([data-theme="dark"]) .icon-moon {
    display: none;
  }

  :global([data-theme="dark"]) .icon-sun {
    display: block;
  }
</style>
