# Immich → Site Photo Sync — environment variables
# Copy to .env.local and fill in values

# Immich (internal Docker network hostname when running as sidecar)
IMMICH_URL=http://immich_server:3001
IMMICH_API_KEY=

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=site-photos

# Public CDN URL for the R2 bucket (no trailing slash)
PHOTOS_CDN_URL=https://assets.lapidak.is

# Path to local clone of the site repo (defaults to current directory)
SITE_REPO_PATH=.

# Git identity for sync commits
GIT_USER_EMAIL=sync@mike.lapidak.is
GIT_USER_NAME=photo-sync

# GitHub Personal Access Token (repo scope) — used for HTTPS push
# Alternative: mount an SSH key and configure SSH instead
GITHUB_TOKEN=
